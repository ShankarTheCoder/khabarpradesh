# Copy this file to .env and fill in real values for your deployment.

# Port the API listens on (most hosting platforms set this automatically)
PORT=5000

# IMPORTANT: change this to a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Optional: comma-separated list of allowed frontend origins.
# Leave unset to allow any origin (fine, since auth uses bearer tokens, not cookies).
# CORS_ORIGIN=https://khabarpradesh.com,https://www.khabarpradesh.com
